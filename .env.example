# Copy this file to .env and fill in your values.
# .env is gitignored — never commit actual credentials.

# Path to your GCP service account JSON key file
VERTEX_AI_CREDENTIALS_FILE=config/vertex-ai.json

# Your GCP project ID
GCP_PROJECT=your-gcp-project-id

# Vertex AI region (optional, default: us-central1)
GCP_LOCATION=us-central1

# Gemini location for publisher models (Gemini 3 Flash should use global)
GEMINI_LOCATION=global

# Gemini model (Vertex AI publisher model)
GEMINI_MODEL=gemini-3-flash-preview
